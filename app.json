{
  "expo": {
    "name": "Luche",
    "slug": "luche-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/luche-app-icon.png",
    "scheme": "luche",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/luche-app-icon.png",
      "bundleIdentifier": "ai.getferal.luche",
      "appleTeamId": "CVR9PS8CQG",
      "supportsTablet": false,
      "infoPlist": {
        "CFBundleDisplayName": "Luche",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ai.getferal.luche",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000C27",
          "image": "./assets/images/luche-app-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Luche uses the camera to record short movement tests for research and wellness and to create experimental estimates.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-secure-store",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cf2e8b60-4dd8-4730-b1bc-80b3d55418a4"
      }
    },
    "owner": "sposiboh"
  }
}
